{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_TOKEN": "$EXPO_TOKEN"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "$APPLE_TEAM_ID",
        "ascApiKeyIssuerId": "$ASC_ISSUER_ID",
        "ascApiKeyId": "$ASC_KEY_ID",
        "ascApiKeyPath": "$ASC_API_KEY_CONTENT"
      },
      "android": {
        "serviceAccountKeyPath": "$GOOGLE_SERVICE_ACCOUNT_KEY",
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
