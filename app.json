{
  "expo": {
    "name": "Diana Travel",
    "slug": "diana-travel-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "diana-travel-mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D13434"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dianatravel.app",
      "buildNumber": "3"
    },
    "android": {
      "package": "com.dianatravel.app",
      "versionCode": 6,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#D13434"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d029df9a-c587-469c-82bb-aeb2ba02251a"
      },
      "privacyPolicyUrl": "https://diana-travel-gateway.replit.app/privacy"
    },
    "owner": "elcheikhghouzayels-organization"
  }
}
